<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
  <title>RID Tech | Course Manager & Neo Dashboard</title>
  <!-- Google Fonts + Font Awesome 6 -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/slidebar.css">
  <link rel="stylesheet" href="/css/courses.css">
  

</head>
<body>
<div class="dashboard">
  <!-- Sidebar Overlay for mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- MODERN SIDEBAR (FULLY RESPONSIVE TOGGLE) -->
  <aside class="sidebar" id="sidebar">
    <div class="logo-area">
      <h2>RID Tech</h2>
      <p>next‑gen learning hub</p>
    </div>
    <div class="nav-menu">
      <a href="/" class="nav-item active"><i class="fas fa-tachometer-alt"></i><span>Dashboard</span></a>
      <a href="/students" class="nav-item"><i class="fas fa-users"></i><span>Students</span></a>
      <a href="/courses" class="nav-item"><i class="fas fa-book-open"></i><span>Courses</span></a>
      <a href="/certificates" class="nav-item"><i class="fas fa-certificate"></i><span>Apply for Certificates</span></a>
      <a href="/test" class="nav-item"><i class="fas fa-plus-circle"></i><span>Create Test</span></a>
      <a href="/collection" class="nav-item"><i class="fas fa-database"></i><span>Test Collection</span></a>
      <a href="/Create_ID" class="nav-item"><i class="fas fa-id-card"></i><span>Create ID card</span></a>
      <a href="/registrations" class="nav-item"><i class="fas fa-file-alt"></i><span>Apply for Franchises</span></a>
      <a href="/fees" class="nav-item"><i class="fas fa-rupee-sign"></i><span>Fee Management</span></a>
      <a href="/Attendence" class="nav-item"><i class="fas fa-calendar-check"></i><span>Attendance</span></a>
      <a href="/results" class="nav-item"><i class="fas fa-chart-bar"></i><span>Result</span></a>
      <a href="/settings" class="nav-item"><i class="fas fa-cog"></i><span>Settings</span></a>
    </div>
  </aside>

  <!-- MAIN CONTENT (Course Manager) -->
  <div class="main-content" id="mainContent">
    <!-- Mobile toggle button placed inside main content -->
    <button class="menu-toggle" id="menuToggleBtn"><i class="fas fa-bars"></i></button>

    <div class="manager-container">
      <div class="manager-header">
        <div class="title-section">
          <h1><i class="fas fa-chalkboard-user" style="margin-right: 10px; color:#2563eb;"></i> All Courses</h1>
          <p><i class="fas fa-chalkboard-user"></i> Manage courses, track enrollments & organize curriculum</p>
        </div>
        <button class="btn-primary" onclick="openModal()"><i class="fas fa-plus-circle"></i> Add Course</button>
      </div>

      <!-- stats + search panel -->
      <div class="stats-search-panel">
        <div class="stats-group">
          <div class="stat-badge"><i class="fas fa-book-open"></i> <span id="totalCoursesCount">0</span> Courses</div>
          <div class="stat-badge"><i class="fas fa-user-graduate"></i> <span id="totalEnrollmentsCount">0</span> Total Enrollments</div>
        </div>
        <div class="search-wrapper">
          <i class="fas fa-search"></i>
          <input type="text" id="searchInput" placeholder="Search by name or category..." autocomplete="off">
        </div>
      </div>

      <!-- dynamic course table panel -->
      <div id="dynamicPanel"></div>
      <!-- <footer>✧ full CRUD · connected to backend API ✧</footer> -->
    </div>
  </div>
</div>

<!-- MODAL for Add/Edit -->
<div id="courseModal" class="modal">
  <div class="modal-content">
    <h3 id="modalTitle">Add New Course</h3>
    <form id="courseForm">
      <div class="form-group">
        <label><i class="fas fa-book"></i> Course Name *</label>
        <input type="text" id="courseName" placeholder="e.g., Full-Stack Web Development" required>
      </div>
      <div class="form-group">
        <label><i class="fas fa-tag"></i> Category *</label>
        <input type="text" id="courseCategory" placeholder="e.g., Development, Data & AI, Design" required>
      </div>
      <div class="form-group">
        <label><i class="fas fa-users"></i> Enrollments</label>
        <input type="number" id="courseEnrollments" placeholder="Number of enrollments" min="0" value="0">
      </div>
      <input type="hidden" id="editCourseId" value="">
      <div class="modal-actions">
        <button type="button" class="cancel-modal" id="cancelModalBtn">Cancel</button>
        <button type="submit" class="save-modal">Save Course</button>
      </div>
    </form>
  </div>
</div>
<div id="toastMsg" class="toast">✅ Action completed</div>

<script>
  // ------------------------------
  // FULL COURSE MANAGER + SIDEBAR TOGGLE (PERFECT RESPONSIVE)
  // ------------------------------
  let courses = [];
  let editMode = false;
  let editId = null;
  let currentSearchTerm = '';

  const API_URL = "/api/courses";

  // Toast helper
  function showToast(msg, isError = false) {
    const toast = document.getElementById('toastMsg');
    toast.textContent = (isError ? '⚠️ ' : '✅ ') + msg;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
  }

  // Fetch courses from backend
  async function fetchCourses() {
    try {
      const res = await fetch(API_URL);
      if (!res.ok) throw new Error("Failed to fetch");
      courses = await res.json();
      renderCourseManager();
    } catch (err) {
      console.error(err);
      showToast("Using demo data (backend not ready)", true);
      // fallback demo data for smooth UI preview
      if (courses.length === 0) {
        courses = [
          { _id: "1", courseName: "UI/UX Design", courseCategory: "Design", courseEnrollments: 124 },
          { _id: "2", courseName: "Machine Learning A-Z", courseCategory: "Data & AI", courseEnrollments: 342 },
          { _id: "3", courseName: "Full-Stack JavaScript", courseCategory: "Development", courseEnrollments: 289 },
          { _id: "4", courseName: "Cloud Computing AWS", courseCategory: "Cloud", courseEnrollments: 178 }
        ];
        renderCourseManager();
      }
    }
  }

  // Create or Update course
  async function handleFormSubmit(e) {
    e.preventDefault();
    const courseName = document.getElementById('courseName').value.trim();
    const courseCategory = document.getElementById('courseCategory').value.trim();
    const courseEnrollments = parseInt(document.getElementById('courseEnrollments').value) || 0;

    if (!courseName || !courseCategory) {
      showToast("Course name and category required", true);
      return;
    }

    const payload = { courseName, courseCategory, courseEnrollments };

    try {
      if (editMode && editId) {
        const res = await fetch(`${API_URL}/${editId}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });
        if (!res.ok) throw new Error("Update failed");
        showToast("Course updated");
      } else {
        const res = await fetch(API_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });
        if (!res.ok) throw new Error("Create failed");
        showToast("Course added");
      }
      closeModal();
      await fetchCourses();
    } catch (err) {
      console.error(err);
      // fallback local update/demo mode
      if (!editMode) {
        const newId = Date.now().toString();
        courses.unshift({ _id: newId, courseName, courseCategory, courseEnrollments });
        renderCourseManager();
        showToast("Demo: Course added locally");
      } else {
        const index = courses.findIndex(c => c._id === editId);
        if (index !== -1) {
          courses[index] = { ...courses[index], courseName, courseCategory, courseEnrollments };
          renderCourseManager();
          showToast("Demo: Course updated locally");
        }
      }
      closeModal();
    }
  }

  // Delete course
  async function deleteCourseById(id) {
    if (!confirm("Delete this course? This action is permanent.")) return;
    try {
      const res = await fetch(`${API_URL}/${id}`, { method: "DELETE" });
      if (!res.ok) throw new Error("Delete failed");
      showToast("Course deleted");
      await fetchCourses();
    } catch (err) {
      courses = courses.filter(c => c._id !== id);
      renderCourseManager();
      showToast("Demo: Course deleted locally");
    }
  }

  // Open modal for add/edit
  function openModal(course = null) {
    const modal = document.getElementById('courseModal');
    if (course) {
      editMode = true;
      editId = course._id;
      document.getElementById('modalTitle').innerText = "Edit Course";
      document.getElementById('courseName').value = course.courseName;
      document.getElementById('courseCategory').value = course.courseCategory;
      document.getElementById('courseEnrollments').value = course.courseEnrollments;
      document.getElementById('editCourseId').value = course._id;
    } else {
      editMode = false;
      editId = null;
      document.getElementById('modalTitle').innerText = "Add New Course";
      document.getElementById('courseForm').reset();
      document.getElementById('courseEnrollments').value = "0";
      document.getElementById('editCourseId').value = "";
    }
    modal.style.display = "flex";
  }

  function closeModal() {
    document.getElementById('courseModal').style.display = "none";
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // Render table, stats, search
  function renderCourseManager() {
    const container = document.getElementById('dynamicPanel');
    if (!container) return;

    let filtered = courses.filter(c =>
      c.courseName.toLowerCase().includes(currentSearchTerm.toLowerCase()) ||
      c.courseCategory.toLowerCase().includes(currentSearchTerm.toLowerCase())
    );

    const totalCourses = courses.length;
    const totalEnrollments = courses.reduce((sum, c) => sum + (c.courseEnrollments || 0), 0);
    document.getElementById('totalCoursesCount').innerText = totalCourses;
    document.getElementById('totalEnrollmentsCount').innerText = totalEnrollments.toLocaleString();

    if (filtered.length === 0) {
      container.innerHTML = `
        <div class="table-wrapper">
          <table class="course-table">
            <thead><tr><th>Course Name</th><th>Category</th><th>Enrollments</th><th>Actions</th></tr></thead>
            <tbody><tr class="empty-row"><td colspan="4"><i class="fas fa-database"></i> No courses match your search. Add a new course!</td></tr></tbody>
          </table>
        </div>
      `;
      return;
    }

    let rows = filtered.map(course => `
      <tr>
        <td><strong>${escapeHtml(course.courseName)}</strong></td>
        <td><span class="category-chip">${escapeHtml(course.courseCategory)}</span></td>
        <td><span class="enroll-value"><i class="fas fa-user-friends"></i> ${course.courseEnrollments.toLocaleString()} enrolled</span></td>
        <td>
          <div class="action-btns">
            <button class="edit-btn" onclick='openModal(${JSON.stringify(course).replace(/'/g, "&#39;")})'>Edit</button>
            <button class="delete-btn" onclick="deleteCourseById('${course._id}')">Delete</button>
          </div>
        </td>
      </tr>
    `).join("");

    container.innerHTML = `
      <div class="table-wrapper">
        <table class="course-table">
          <thead><tr><th>Course Name</th><th>Category</th><th>Enrollments</th><th>Actions</th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;
  }

  // SIDEBAR TOGGLE LOGIC (fully responsive, works on all devices)
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');
  const menuToggleBtn = document.getElementById('menuToggleBtn');

  function openSidebar() {
    if (sidebar) sidebar.classList.add('open');
    if (overlay) overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    if (sidebar) sidebar.classList.remove('open');
    if (overlay) overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  function toggleSidebar() {
    if (sidebar && sidebar.classList.contains('open')) {
      closeSidebar();
    } else {
      openSidebar();
    }
  }

  // Attach event listeners for sidebar controls
  if (menuToggleBtn) {
    menuToggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleSidebar();
    });
  }
  if (overlay) {
    overlay.addEventListener('click', closeSidebar);
  }

  // On resize, handle sidebar state: if screen > 768 and sidebar was open forced? Reset
  function handleResize() {
    if (window.innerWidth > 768) {
      // ensure sidebar is visible by removing transform but keep open class? Remove open class for clean state
      if (sidebar) sidebar.classList.remove('open');
      if (overlay) overlay.classList.remove('active');
      document.body.style.overflow = '';
    } else {
      // On small screens, if sidebar gets stuck open without overlay? ensure overlay sync
      if (sidebar && sidebar.classList.contains('open')) {
        overlay.classList.add('active');
      } else {
        overlay.classList.remove('active');
      }
    }
  }

  window.addEventListener('resize', handleResize);
  document.addEventListener('keydown', (e) => { if (e.key === "Escape") closeSidebar(); });
  // Close any nav links on mobile after click
  document.querySelectorAll('.nav-item').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 768) {
        closeSidebar();
      }
    });
  });

  // highlight current active based on href (simple)
  const currentPath = window.location.pathname;

document.querySelectorAll('.nav-item').forEach(link => {
  link.classList.remove('active');

  const href = link.getAttribute('href');

  if (href === currentPath) {
    link.classList.add('active');
  }
});
  if (currentPath === '/' || currentPath === '') {
    document.querySelector('.nav-item[href="/"]')?.classList.add('active');
  }

  // Initialise everything
  document.getElementById('courseForm').addEventListener('submit', handleFormSubmit);
  document.getElementById('cancelModalBtn').addEventListener('click', closeModal);
  window.addEventListener('click', (e) => {
    if (e.target.id === 'courseModal') closeModal();
  });
  const searchInput = document.getElementById('searchInput');
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      currentSearchTerm = e.target.value;
      renderCourseManager();
    });
  }
  handleResize(); // initial call
  fetchCourses();
</script>
</body>
</html>